# =============================================================================
# Crypto Trading Bot Pro - Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your actual values.
# NEVER commit your .env file to version control.
# =============================================================================

# --- Binance API ---
# Get your API key and secret from: https://www.binance.com/en/my/settings/api-management
# Make sure to enable Futures trading permission on your API key.
BINANCE_API_KEY=your_binance_api_key_here
BINANCE_API_SECRET=your_binance_api_secret_here

# Set to "true" to use Binance Testnet (recommended for initial testing)
BINANCE_TESTNET=false

# --- Telegram Notifications ---
# Create a bot via @BotFather on Telegram to get your bot token.
# Send a message to your bot, then visit:
# https://api.telegram.org/bot<YOUR_TOKEN>/getUpdates to find your chat ID.
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# --- Logging ---
# Options: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
